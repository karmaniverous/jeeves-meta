{
  "name": "jeeves-meta-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=packages/openclaw && npm run build --workspace=packages/service",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "npm run test --workspace=packages/openclaw && npm run test --workspace=packages/service",
    "typecheck": "npm run typecheck --workspace=packages/openclaw && npm run typecheck --workspace=packages/service",
    "docs": "typedoc"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@eslint/js": "^10.0.1",
    "@vitest/eslint-plugin": "^1.6.13",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-tsdoc": "^0.5.2",
    "jiti": "^2.6.1",
    "knip": "^6.1.0",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typedoc": "^0.28.18",
    "typedoc-plugin-mdn-links": "^5.1.1",
    "typedoc-plugin-replace-text": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "engines": {
    "node": ">=22"
  }
}
