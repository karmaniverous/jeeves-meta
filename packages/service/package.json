{
  "name": "@karmaniverous/jeeves-meta",
  "version": "0.13.2",
  "author": "Jason Williscroft",
  "description": "Fastify HTTP service for the Jeeves Meta synthesis engine",
  "license": "BSD-3-Clause",
  "type": "module",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/karmaniverous/jeeves-meta.git",
    "directory": "packages/service"
  },
  "bugs": {
    "url": "https://github.com/karmaniverous/jeeves-meta/issues"
  },
  "homepage": "https://github.com/karmaniverous/jeeves-meta#readme",
  "keywords": [
    "synthesis",
    "knowledge",
    "meta",
    "jeeves",
    "service",
    "fastify",
    "typescript"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@karmaniverous/jeeves": "^0.5.4",
    "commander": "^14",
    "croner": "^10",
    "fastify": "^5.8",
    "handlebars": "^4.7.9",
    "package-directory": "^8.2.0",
    "pino": "^10",
    "zod": "^4.3"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@dotenvx/dotenvx": "^1.59.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "auto-changelog": "^2.5.0",
    "cross-env": "^10.1.0",
    "knip": "^5.87.0",
    "release-it": "^19.2.4",
    "rollup": "^4.60.1",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "build": "rimraf dist && cross-env NO_COLOR=1 rollup --config rollup.config.mjs",
    "knip": "knip",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "typecheck": "tsc",
    "changelog": "auto-changelog",
    "release": "dotenvx run -f .env.local -- release-it",
    "release:pre": "dotenvx run -f .env.local -- release-it --no-git.requireBranch --github.prerelease --preRelease"
  },
  "bin": {
    "jeeves-meta": "./dist/cli/jeeves-meta/index.js"
  },
  "release-it": {
    "git": {
      "changelog": "npx auto-changelog --unreleased-only --stdout --template https://raw.githubusercontent.com/release-it/release-it/main/templates/changelog-compact.hbs",
      "commitMessage": "chore: release @karmaniverous/jeeves-meta v${version}",
      "tagName": "service/${version}",
      "requireBranch": "main"
    },
    "github": {
      "release": true
    },
    "hooks": {
      "after:init": [
        "npm run lint",
        "npm run typecheck",
        "npm run test",
        "npm run build"
      ],
      "before:npm:release": [
        "npx auto-changelog -p",
        "git add -A"
      ],
      "after:release": [
        "git switch -c release/service/${version}",
        "git push -u origin release/service/${version}",
        "git switch ${branchName}"
      ]
    },
    "npm": {
      "publish": true
    }
  },
  "auto-changelog": {
    "output": "CHANGELOG.md",
    "tagPrefix": "service/",
    "unreleased": true,
    "commitLimit": false,
    "hideCredit": true
  }
}
