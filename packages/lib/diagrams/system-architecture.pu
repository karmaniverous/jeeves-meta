@startuml system-architecture

skinparam backgroundColor #FFFFFF
skinparam componentBackgroundColor #E8EAF6
skinparam componentBorderColor #3F51B5
skinparam databaseBackgroundColor #FFF3E0
skinparam databaseBorderColor #FF9800
skinparam packageBackgroundColor #F3E5F5
skinparam packageBorderColor #9C27B0
skinparam arrowColor #37474F
skinparam defaultFontSize 13

title jeeves-synth — System Architecture

package "Scheduling" {
  [jeeves-runner] as runner
}

package "Synthesis Engine" {
  [orchestrate()] as orch
  [discovery] as disc
  [scheduling] as sched
  [archive] as arch
}

package "LLM Pipeline" {
  [Architect] as architect
  [Builder] as builder
  [Critic] as critic
}

package "Data Access" {
  [WatcherClient] as wc
  [SynthExecutor] as exec
}

database "Filesystem" {
  [.meta/meta.json] as meta
  [.meta/archive/] as archive
  [source files] as src
}

database "jeeves-watcher" {
  [POST /scan] as scan
  [POST /search] as search
}

runner --> orch : cron trigger
orch --> disc : glob .meta/ dirs
orch --> sched : rank candidates
orch --> arch : snapshot + prune

orch --> architect : step 1 (conditional)
architect --> builder : _builder brief
builder --> critic : _content
critic --> orch : _feedback

orch --> meta : read/write
orch --> archive : snapshot
builder --> src : read files

wc --> scan : structured queries
wc --> search : semantic queries
exec --> architect : spawn
exec --> builder : spawn
exec --> critic : spawn

@enduml
